mainmenu "IoT Server"

menu "Application configuration"

config OT_COAP_SAMPLE_SERVER
	bool "Build the sample CoAP server application"

config OT_COAP_SAMPLE_LED
	bool "Enable LED support"
	default y

config OT_COAP_SAMPLE_SW
	bool "Enable switch support"
	default y

config OT_COAP_SHELL
	bool "Enable switch support"
	default n

config XXX_IMU
    bool "Enable AS201 IMU Support"
    default n
    help 
      This option enables the custom AS201 inertial measurement unit driver logic.

config LD2410C_DDRS
    bool "Enable LD2410C DDRS Support"
    default n
    help 
      This option enables the custom LD2410C Distance Detection Radar Sensor driver logic.

config AHT20_TS
    bool "Enable AHT20 TS Support"
    default n
    help 
      This option enables the custom AHT20 temperature sensor driver logic.

config BMP280_PS
    bool "Enable BMP280 Support"
    default n
    help 
      This option enables the custom BMP280 pressure sensor driver logic.

config LED_CT
    bool "Enable BLINK Support"
    default n
    help 
      This option enables the custom BLINK driver logic.

config BUTTON_CT
    bool "Enable BUTTON Support"
    default n
    help 
      This option enables the custom BLINK driver logic.

config OPEN_THREAD
    bool "Enable OPEN THREAD Support"
    default n
    help 
      This option enables the custom OPEN THREAD driver logic.

endmenu

source "Kconfig.zephyr"
